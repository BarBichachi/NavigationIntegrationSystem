<?xml version="1.0" encoding="utf-8" ?>
<UserControl x:Class="NavigationIntegrationSystem.UI.Views.Panes.SubViews.Vn310InspectView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <!--  Right padding (16) inside the ScrollViewer leaves room for the overlay scrollbar so it doesn't paint on top of the value/unit columns when content overflows. Matches the Settings pane's visual rhythm: section borders, 14px between sections, 10px between rows  -->
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" Padding="0,0,16,0">
        <StackPanel Spacing="14">

            <!--  Not-connected banner: visible whenever the device isn't Connected. Text varies based on whether any packet has ever arrived (so the user knows whether they're seeing frozen-last-values or no data at all)  -->
            <Border Padding="10" CornerRadius="6"
                    Background="{ThemeResource SystemFillColorNeutralBackgroundBrush}"
                    BorderBrush="{ThemeResource SystemFillColorNeutralBrush}"
                    BorderThickness="1"
                    Visibility="{Binding IsNotConnectedBannerVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE8CD;" FontSize="14" VerticalAlignment="Top"
                              Foreground="{ThemeResource SystemFillColorNeutralBrush}" />
                    <TextBlock Text="{Binding NotConnectedBannerText}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!--  ASCII-mode banner: surfaces why angular rates show '—'. Info-blue (not caution-yellow) because it's a config note, not a warning  -->
            <Border Padding="10" CornerRadius="6"
                    Background="{ThemeResource SystemFillColorAttentionBackgroundBrush}"
                    BorderBrush="{ThemeResource SystemFillColorAttentionBrush}"
                    BorderThickness="1"
                    Visibility="{Binding IsAsciiBannerVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE946;" FontSize="14" VerticalAlignment="Top"
                              Foreground="{ThemeResource SystemFillColorAttentionBrush}" />
                    <TextBlock Text="Rates not available — sensor is configured for ASCII VNINS. Reconfigure factory output to binary to enable angular rate fields."
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!--  Binary-mode banner: surfaces why uncertainty fields show '—'. Also info-blue  -->
            <Border Padding="10" CornerRadius="6"
                    Background="{ThemeResource SystemFillColorAttentionBackgroundBrush}"
                    BorderBrush="{ThemeResource SystemFillColorAttentionBrush}"
                    BorderThickness="1"
                    Visibility="{Binding IsBinaryBannerVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE946;" FontSize="14" VerticalAlignment="Top"
                              Foreground="{ThemeResource SystemFillColorAttentionBrush}" />
                    <TextBlock Text="Uncertainty fields not available — current binary subscription is CommonGroup + TimeGroup only. Extend to AttitudeGroup / InsGroup for AttU / PosU / VelU."
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!--  Current telemetry  -->
            <Border Padding="12" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="10">
                <StackPanel Spacing="10">
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="Current telemetry" />
                    <Grid ColumnSpacing="12" RowSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="60" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"  Grid.Column="0" Opacity="0.7" Text="UTC Time" VerticalAlignment="Center" />
                        <TextBlock Grid.Row="0"  Grid.Column="1" HorizontalAlignment="Right" FontFamily="Consolas" Text="{Binding UtcTimeText}" />

                        <TextBlock Grid.Row="1"  Grid.Column="0" Opacity="0.7" Text="Latitude" VerticalAlignment="Center" />
                        <TextBlock Grid.Row="1"  Grid.Column="1" HorizontalAlignment="Right" FontFamily="Consolas" Text="{Binding LatText}" />
                        <TextBlock Grid.Row="1"  Grid.Column="2" HorizontalAlignment="Right" Opacity="0.55" Text="deg" />

                        <TextBlock Grid.Row="2"  Grid.Column="0" Opacity="0.7" Text="Longitude" VerticalAlignment="Center" />
                        <TextBlock Grid.Row="2"  Grid.Column="1" HorizontalAlignment="Right" FontFamily="Consolas" Text="{Binding LonText}" />
                        <TextBlock Grid.Row="2"  Grid.Column="2" HorizontalAlignment="Right" Opacity="0.55" Text="deg" />

                        <TextBlock Grid.Row="3"  Grid.Column="0" Opacity="0.7" Text="Altitude" VerticalAlignment="Center" />
                        <TextBlock Grid.Row="3"  Grid.Column="1" HorizontalAlignment="Right" FontFamily="Consolas" Text="{Binding AltText}" />
                        <TextBlock Grid.Row="3"  Grid.Column="2" HorizontalAlignment="Right" Opacity="0.55" Text="m" />

                        <TextBlock Grid.Row="4"  Grid.Column="0" Opacity="0.7" Text="Yaw" VerticalAlignment="Center" />
                        <TextBlock Grid.Row="4"  Grid.Column="1" HorizontalAlignment="Right" FontFamily="Consolas" Text="{Binding YawText}" />
                        <TextBlock Grid.Row="4"  Grid.Column="2" HorizontalAlignment="Right" Opacity="0.55" Text="deg" />

                        <TextBlock Grid.Row="5"  Grid.Column="0" Opacity="0.7" Text="Pitch" VerticalAlignment="Center" />
                        <TextBlock Grid.Row="5"  Grid.Column="1" HorizontalAlignment="Right" FontFamily="Consolas" Text="{Binding PitchText}" />
                        <TextBlock Grid.Row="5"  Grid.Column="2" HorizontalAlignment="Right" Opacity="0.55" Text="deg" />

                        <TextBlock Grid.Row="6"  Grid.Column="0" Opacity="0.7" Text="Roll" VerticalAlignment="Center" />
                        <TextBlock Grid.Row="6"  Grid.Column="1" HorizontalAlignment="Right" FontFamily="Consolas" Text="{Binding RollText}" />
                        <TextBlock Grid.Row="6"  Grid.Column="2" HorizontalAlignment="Right" Opacity="0.55" Text="deg" />

                        <TextBlock Grid.Row="7"  Grid.Column="0" Opacity="0.7" Text="Yaw Rate" VerticalAlignment="Center" />
                        <TextBlock Grid.Row="7"  Grid.Column="1" HorizontalAlignment="Right" FontFamily="Consolas" Text="{Binding YawRateText}" />
                        <TextBlock Grid.Row="7"  Grid.Column="2" HorizontalAlignment="Right" Opacity="0.55" Text="deg/s" />

                        <TextBlock Grid.Row="8"  Grid.Column="0" Opacity="0.7" Text="Pitch Rate" VerticalAlignment="Center" />
                        <TextBlock Grid.Row="8"  Grid.Column="1" HorizontalAlignment="Right" FontFamily="Consolas" Text="{Binding PitchRateText}" />
                        <TextBlock Grid.Row="8"  Grid.Column="2" HorizontalAlignment="Right" Opacity="0.55" Text="deg/s" />

                        <TextBlock Grid.Row="9"  Grid.Column="0" Opacity="0.7" Text="Roll Rate" VerticalAlignment="Center" />
                        <TextBlock Grid.Row="9"  Grid.Column="1" HorizontalAlignment="Right" FontFamily="Consolas" Text="{Binding RollRateText}" />
                        <TextBlock Grid.Row="9"  Grid.Column="2" HorizontalAlignment="Right" Opacity="0.55" Text="deg/s" />

                        <TextBlock Grid.Row="10" Grid.Column="0" Opacity="0.7" Text="Velocity North" VerticalAlignment="Center" />
                        <TextBlock Grid.Row="10" Grid.Column="1" HorizontalAlignment="Right" FontFamily="Consolas" Text="{Binding VelNorthText}" />
                        <TextBlock Grid.Row="10" Grid.Column="2" HorizontalAlignment="Right" Opacity="0.55" Text="m/s" />

                        <TextBlock Grid.Row="11" Grid.Column="0" Opacity="0.7" Text="Velocity East" VerticalAlignment="Center" />
                        <TextBlock Grid.Row="11" Grid.Column="1" HorizontalAlignment="Right" FontFamily="Consolas" Text="{Binding VelEastText}" />
                        <TextBlock Grid.Row="11" Grid.Column="2" HorizontalAlignment="Right" Opacity="0.55" Text="m/s" />

                        <TextBlock Grid.Row="12" Grid.Column="0" Opacity="0.7" Text="Velocity Down" VerticalAlignment="Center" />
                        <TextBlock Grid.Row="12" Grid.Column="1" HorizontalAlignment="Right" FontFamily="Consolas" Text="{Binding VelDownText}" />
                        <TextBlock Grid.Row="12" Grid.Column="2" HorizontalAlignment="Right" Opacity="0.55" Text="m/s" />

                        <TextBlock Grid.Row="13" Grid.Column="0" Opacity="0.7" Text="Speed" VerticalAlignment="Center" />
                        <TextBlock Grid.Row="13" Grid.Column="1" HorizontalAlignment="Right" FontFamily="Consolas" Text="{Binding SpeedText}" />
                        <TextBlock Grid.Row="13" Grid.Column="2" HorizontalAlignment="Right" Opacity="0.55" Text="m/s" />

                        <TextBlock Grid.Row="14" Grid.Column="0" Opacity="0.7" Text="Att Uncertainty" VerticalAlignment="Center" />
                        <TextBlock Grid.Row="14" Grid.Column="1" HorizontalAlignment="Right" FontFamily="Consolas" Text="{Binding AttUncertaintyText}" />

                        <TextBlock Grid.Row="15" Grid.Column="0" Opacity="0.7" Text="Pos Uncertainty" VerticalAlignment="Center" />
                        <TextBlock Grid.Row="15" Grid.Column="1" HorizontalAlignment="Right" FontFamily="Consolas" Text="{Binding PosUncertaintyText}" />

                        <TextBlock Grid.Row="16" Grid.Column="0" Opacity="0.7" Text="Vel Uncertainty" VerticalAlignment="Center" />
                        <TextBlock Grid.Row="16" Grid.Column="1" HorizontalAlignment="Right" FontFamily="Consolas" Text="{Binding VelUncertaintyText}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!--  INS Status decoded  -->
            <Border Padding="12" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="10">
                <StackPanel Spacing="10">
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="INS Status" />
                    <Grid ColumnSpacing="12" RowSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Opacity="0.7" Text="Mode" VerticalAlignment="Center" />
                        <TextBlock Grid.Row="0" Grid.Column="1" HorizontalAlignment="Right" FontFamily="Consolas" Text="{Binding InsModeText}" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Opacity="0.7" Text="Raw" VerticalAlignment="Center" />
                        <TextBlock Grid.Row="1" Grid.Column="1" HorizontalAlignment="Right" FontFamily="Consolas" Text="{Binding InsStatusRawText}" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Opacity="0.7" Text="GPS Fix" VerticalAlignment="Center" />
                        <TextBlock Grid.Row="2" Grid.Column="1" HorizontalAlignment="Right" FontFamily="Consolas" Text="{Binding IsGpsFixText}" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Opacity="0.7" Text="GPS Heading INS" VerticalAlignment="Center" />
                        <TextBlock Grid.Row="3" Grid.Column="1" HorizontalAlignment="Right" FontFamily="Consolas" Text="{Binding IsGpsHeadingInsText}" />

                        <TextBlock Grid.Row="4" Grid.Column="0" Opacity="0.7" Text="GPS Compass Active" VerticalAlignment="Center" />
                        <TextBlock Grid.Row="4" Grid.Column="1" HorizontalAlignment="Right" FontFamily="Consolas" Text="{Binding IsGpsCompassActiveText}" />

                        <TextBlock Grid.Row="5" Grid.Column="0" Opacity="0.7" Text="IMU Error" VerticalAlignment="Center" />
                        <TextBlock Grid.Row="5" Grid.Column="1" HorizontalAlignment="Right" FontFamily="Consolas" Text="{Binding IsImuErrorText}" />

                        <TextBlock Grid.Row="6" Grid.Column="0" Opacity="0.7" Text="Magnetometer Error" VerticalAlignment="Center" />
                        <TextBlock Grid.Row="6" Grid.Column="1" HorizontalAlignment="Right" FontFamily="Consolas" Text="{Binding IsMagnetometerErrorText}" />

                        <TextBlock Grid.Row="7" Grid.Column="0" Opacity="0.7" Text="GNSS Error" VerticalAlignment="Center" />
                        <TextBlock Grid.Row="7" Grid.Column="1" HorizontalAlignment="Right" FontFamily="Consolas" Text="{Binding IsGnssErrorText}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!--  Time Status decoded  -->
            <Border Padding="12" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="10">
                <StackPanel Spacing="10">
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="Time Status" />
                    <Grid ColumnSpacing="12" RowSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Opacity="0.7" Text="Raw" VerticalAlignment="Center" />
                        <TextBlock Grid.Row="0" Grid.Column="1" HorizontalAlignment="Right" FontFamily="Consolas" Text="{Binding TimeStatusRawText}" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Opacity="0.7" Text="Time OK" VerticalAlignment="Center" />
                        <TextBlock Grid.Row="1" Grid.Column="1" HorizontalAlignment="Right" FontFamily="Consolas" Text="{Binding IsTimeOkText}" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Opacity="0.7" Text="Date OK" VerticalAlignment="Center" />
                        <TextBlock Grid.Row="2" Grid.Column="1" HorizontalAlignment="Right" FontFamily="Consolas" Text="{Binding IsDateOkText}" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Opacity="0.7" Text="UTC Time Valid" VerticalAlignment="Center" />
                        <TextBlock Grid.Row="3" Grid.Column="1" HorizontalAlignment="Right" FontFamily="Consolas" Text="{Binding IsUtcTimeValidText}" />

                        <TextBlock Grid.Row="4" Grid.Column="0" Opacity="0.7" Text="Valid (all)" VerticalAlignment="Center" />
                        <TextBlock Grid.Row="4" Grid.Column="1" HorizontalAlignment="Right" FontFamily="Consolas" Text="{Binding IsTimeStatusValidText}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!--  Packet stats  -->
            <Border Padding="12" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="10">
                <StackPanel Spacing="10">
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="Packet stats" />
                    <Grid ColumnSpacing="12" RowSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Opacity="0.7" Text="Total received" VerticalAlignment="Center" />
                        <TextBlock Grid.Row="0" Grid.Column="1" HorizontalAlignment="Right" FontFamily="Consolas" Text="{Binding PacketCountText}" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Opacity="0.7" Text="Rate (1s window)" VerticalAlignment="Center" />
                        <TextBlock Grid.Row="1" Grid.Column="1" HorizontalAlignment="Right" FontFamily="Consolas" Text="{Binding PacketRateText}" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Opacity="0.7" Text="Last packet age" VerticalAlignment="Center" />
                        <TextBlock Grid.Row="2" Grid.Column="1" HorizontalAlignment="Right" FontFamily="Consolas" Text="{Binding LastPacketAgeText}" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Opacity="0.7" Text="Source mode" VerticalAlignment="Center" />
                        <TextBlock Grid.Row="3" Grid.Column="1" HorizontalAlignment="Right" FontFamily="Consolas" Text="{Binding SourceModeText}" />
                    </Grid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
