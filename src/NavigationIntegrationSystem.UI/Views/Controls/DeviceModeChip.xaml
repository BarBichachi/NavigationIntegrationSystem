<?xml version="1.0" encoding="utf-8" ?>
<UserControl x:Class="NavigationIntegrationSystem.UI.Views.Controls.DeviceModeChip"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <!-- Compact colored pill conveying the device's self-reported mode. Background = severity color; visibility collapses on Severity=Unknown so devices with no mode concept (Manual, Playback) render nothing without the caller branching -->
    <Border Background="{x:Bind Severity, Mode=OneWay, Converter={StaticResource DeviceModeSeverityToBrushConverter}}"
            Visibility="{x:Bind Severity, Mode=OneWay, Converter={StaticResource DeviceModeSeverityToVisibilityConverter}}"
            CornerRadius="8" Padding="8,2" VerticalAlignment="Center">
        <TextBlock Text="{x:Bind Label, Mode=OneWay}" Foreground="White" FontSize="10" FontWeight="SemiBold" />
    </Border>
</UserControl>
