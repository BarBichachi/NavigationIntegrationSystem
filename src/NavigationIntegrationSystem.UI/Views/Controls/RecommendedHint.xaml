<?xml version="1.0" encoding="utf-8" ?>
<UserControl x:Class="NavigationIntegrationSystem.UI.Views.Controls.RecommendedHint"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <!-- Italic, muted hint text. Collapses entirely when Text is null/empty so callers can stamp <RecommendedHint /> above every input unconditionally and let null hints disappear -->
    <TextBlock Text="{x:Bind Text, Mode=OneWay}"
               Visibility="{x:Bind Text, Mode=OneWay, Converter={StaticResource StringNullOrEmptyToVisibilityConverter}}"
               Style="{StaticResource RecommendedHintTextStyle}" />
</UserControl>
